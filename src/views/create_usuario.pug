extends layouts/main.pug

block content

    style.
        :root {
            --primary-green: #27ae60;
            --secondary-blue: #2980b9;
            --dark-green: #1e8449;
            --bg-white: #f9fbfd;
            --text-dark: #2c3e50;
            --white: #ffffff;
        }

        .form-container {
            display: flex;
            justify-content: center;
            margin-top: 40px;
        }

        .form-card {
            width: 100%;
            max-width: 520px;
            background: var(--white);
            border-radius: 12px;
            padding: 30px;
            border-top: 5px solid var(--primary-green);
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

        .card-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .card-header h3 {
            color: var(--secondary-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 24px;
            margin: 0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-dark);
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #dfe6e9;
            border-radius: 10px;
            background-color: var(--bg-white);
            font-size: 15px;
            color: var(--text-dark);
            transition: all 0.3s ease;
            outline: none;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--secondary-blue);
            background-color: var(--white);
            box-shadow: 0 0 0 4px rgba(41, 128, 185, 0.15);
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(
                135deg,
                var(--primary-green) 0%,
                var(--secondary-blue) 100%
            );
            color: var(--white);
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(39, 174, 96, 0.25);
        }

    .form-container
        .form-card

            .card-header
                h3
                    i.fas.fa-user-plus
                    span Criar Novo Usuário

            .card-body

                form(action="/api/usuarios" method="POST")

                    .form-group
                        label(for="nome")
                            i.fas.fa-user
                            |  Nome

                        input(
                            type="text"
                            name="nome"
                            id="nome"
                            placeholder="Digite o nome"
                            required
                        )

                    .form-group
                        label(for="email")
                            i.fas.fa-envelope
                            |  E-mail

                        input(
                            type="email"
                            name="email"
                            id="email"
                            placeholder="Digite o e-mail"
                            required
                        )

                    .form-group
                        label(for="senha")
                            i.fas.fa-lock
                            |  Senha

                        input(
                            type="password"
                            name="senha"
                            id="senha"
                            placeholder="Digite a senha"
                            required
                        )

                    .form-group
                        label(for="nivelAcesso")
                            i.fas.fa-user-shield
                            |  Nível de Acesso

                        select(
                            name="nivelAcesso"
                            id="nivelAcesso"
                            required
                        )
                            option(value="") Selecione o nível
                            option(value="Gestor") Gestor
                            option(value="Colaborador") Colaborador

                    button.btn-submit(type="submit")
                        i.fas.fa-save
                        |  Criar Usuário